# docker compose で参照される。コピーして .env を作って使う。

DB_NAME=nazobu
DB_USER=nazobu
DB_PASSWORD=nazobu_password
DB_ROOT_PASSWORD=nazobu_root_password

# Discord OAuth
# https://discord.com/developers/applications で application を作成し
# OAuth2 → Redirects に http://localhost:3000/auth/discord/callback を登録、
# Client ID / Client Secret を以下に設定する。
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:3000/auth/discord/callback

# Discord リマインド通知の投稿先 webhook URL
# 投稿したいチャンネルの「連携サービス」→「ウェブフックを作成」で発行して貼る。
# 未設定（空）ならリマインドワーカーは起動しない（ローカル開発の既定）。
DISCORD_WEBHOOK_URL=

# Cloudflare Tunnel（compose.prod.yaml でのみ使用）
CLOUDFLARE_TUNNEL_TOKEN=
